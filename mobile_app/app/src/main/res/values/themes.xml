<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base app theme.
        windowNoTitle and windowActionBar = false because we use
        Jetpack Compose for all UI — no XML action bars needed.
        All theming is handled in Compose via MaterialTheme.
    -->
    <style name="Theme.SENTRY" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_600</item>
        <item name="colorPrimaryVariant">@color/teal_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_500</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/teal_700</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowBackground">@color/neutral_50</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.SENTRY.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/teal_700</item>
        <item name="postSplashScreenTheme">@style/Theme.SENTRY</item>
    </style>

</resources>