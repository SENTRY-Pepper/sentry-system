# OpenAI / LLM
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4

# Embedding model (local, no key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./knowledge_base/vector_store
CHROMA_COLLECTION_NAME=sentry_knowledge

# Middleware Server
MIDDLEWARE_HOST=0.0.0.0
MIDDLEWARE_PORT=8000

# Pepper connection (Timothy's layer)
PEPPER_IP=192.168.x.x
PEPPER_PORT=9559

# Backend DB (Timothy's layer)
DATABASE_URL=postgresql://user:password@localhost:5432/sentry_db

# Evaluation
EVAL_LOG_DIR=./evaluation/logs

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/sentry_db
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:yourpassword@localhost:5432/sentry_db

# Network — Android app connection
LAPTOP_LOCAL_IP=192.168.x.x