enario Type","examples":["phishing","usb_drop","password","network","social_engineering"]},"decision":{"type":"string","title":"Decision","description":"'correct' or 'risky'"},"employee_response":{"anyOf":[{"type":"string","maxLength":500},{"type":"null"}],"title":"Employee Response"},"response_time_ms":{"anyOf":[{"type":"integer","minimum":0.0},{"type":"null"}],"title":"Response Time Ms"},"correction_loops":{"type":"integer","minimum":0.0,"title":"Correction Loops","default":0},"ai_latency_ms":{"anyOf":[{"type":"number","minimum":0.0},{"type":"null"}],"title":"Ai Latency Ms"},"ai_sources":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Ai Sources","description":"Comma-separated source document names."}},"type":"object","required":["session_id","scenario_id","scenario_type","decision"],"title":"InteractionLogRequest","description":"Sent by the app after each scenario interaction completes.\nLogs the employee's decision and associated metrics."},"InteractionLogResponse":{"properties":{"interaction_id":{"type":"string","title":"Interaction Id"},"session_id":{"type":"string","title":"Session Id"},"scenario_id":{"type":"string","title":"Scenario Id"},"decision":{"type":"string","title":"Decision"},"logged":{"type":"boolean","title":"Logged"}},"type":"object","required":["interaction_id","session_id","scenario_id","decision","logged"],"title":"InteractionLogResponse","description":"Confirmation of a logged interaction."},"OrganisationAnalytics":{"properties":{"organisation_id":{"type":"string","title":"Organisation Id"},"total_sessions":{"type":"integer","title":"Total Sessions"},"completed_sessions":{"type":"integer","title":"Completed Sessions"},"mean_pre_score":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Mean Pre Score"},"mean_post_score":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Mean Post Score"},"mean_knowledge_gain":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Mean Knowledge Gain"},"mean_grounding_accuracy":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Mean Grounding Accuracy"},"mean_hallucination_rate":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Mean Hallucination Rate"}},"type":"object","required":["organisation_id","total_sessions","completed_sessions","mean_pre_score","mean_post_score","mean_knowledge_gain","mean_grounding_accuracy","mean_hallucination_rate"],"title":"OrganisationAnalytics","description":"Aggregated analytics for an organisation's training sessions."},"QueryRequest":{"properties":{"query":{"type":"string","maxLength":500,"minLength":3,"title":"Query","description":"The user's cybersecurity question captured by Pepper.","examples":["What is phishing and how do I avoid it?"]},"doc_type_filter":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Doc Type Filter","description":"Optional filter to restrict retrieval to a document type. Accepted values: 'owasp', 'legal'. Null searches all sources."},"scenario_id":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Scenario Id","description":"Optional scenario identifier from Timothy's dialogue system. Logged for session traceability in the evaluation study.","examples":["phishing-01","usb-drop-03"]}},"type":"object","required":["query"],"title":"QueryRequest","description":"Incoming query from the Pepper robot.\nSent as a POST body to /api/v1/query or /api/v1/query/baseline."},"QueryResponse":{"properties":{"query":{"type":"string","title":"Query","description":"The original question."},"mode":{"type":"string","title":"Mode","description":"'grounded' or 'baseline'."},"response":{"type":"string","title":"Response","description":"The generated cybersecurity answer."},"sources":{"items":{"type":"string"},"type":"array","title":"Sources","description":"Source documents used to ground the response."},"retrieved_chunks":{"items":{"$ref":"#/components/schemas/RetrievedChunk"},"type":"array","title":"Retrieved Chunks","description":"Chunks retrieved from ChromaDB (grounded mode only).","default":[]},"chunks_use